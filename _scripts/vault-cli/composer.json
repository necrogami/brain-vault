{
    "name": "vault/cli",
    "description": "CLI tool for the Idea & Memory Vault",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "ext-pdo_sqlite": "*",
        "symfony/console": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Vault\\": "src/"
        }
    },
    "bin": ["bin/vault"],
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "require-dev": {
        "pestphp/pest": "*",
        "pestphp/pest-plugin-type-coverage": "*"
    }
}
